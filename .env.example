# M1 剧本生成(Claude API)
ANTHROPIC_API_KEY=

# M2 视觉素材(gpt 出图端口,直连中转站)
MMG_API_URL=https://5yuantoken.org/v1
MMG_API_KEY=
MMG_MODEL=gpt-5.5

# AI DM 说书人(可选,不配则不启用)
DM_PROVIDER=anthropic          # anthropic | openai
DM_API_KEY=                    # 对应 provider 的 API key
DM_API_URL=                    # 仅 openai 模式需要(中转站地址)
DM_MODEL=claude-haiku-4-5      # 快速模型,推荐 haiku 或 flash 级别

# M3 游戏服务器
PORT=8080
