{
  "name": "@mmg/schema",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "剧本杀系统 · 剧本数据契约(脊椎)。M1 生成、M2 回填、M3 运行均以此为准。",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "default": "./src/constants.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
