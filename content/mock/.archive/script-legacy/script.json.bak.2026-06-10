      "id": "p_backstory",
      "kind": "briefing",
      "title": "案前风云",
      "instruction": "每个人眼中的公馆都不一样。阅读属于你的那一段往事。",
      "participants": "all",
      "allowedActions": [
        "readScript",
        "ready"
      ],
      "unlocks": {
        "storyKey": "backstory"
      },
      "exit": {
