[
  {
    "id": "cl_01",
    "title": "浦诚学的最后一封信",
    "content": "浦诚学写给颜睦宛的信末尾写道：「黑暗中，隐藏着比你说的鱼更可怕的怪物——它甚至能洞悉人的内心，让人看到希望的样子，我可能已经遇到了它……」",
    "sceneId": "sc_cargo",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "npc_puchengxue",
      "npc_fanzongchu"
    ]
  },
  {
    "id": "cl_02",
    "title": "刻字怀表",
    "content": "船长欧闻随身携带的怀表上刻有特殊标志和文字——这是颜睦宛送给浦诚学的礼物，浦诚学承诺无论陆地还是海底都会带在身边。怀表为何在船长手中？",
    "sceneId": "sc_bridge",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "npc_ouwen",
      "npc_puchengxue"
    ]
  },
  {
    "id": "cl_03",
    "title": "仓库失火痕迹",
    "content": "毗海村工厂仓库曾于1913年发生火灾，于跃洋的样品和图纸被全部烧毁。火灾原因从未查明——有人在仓库外用烟头点火。",
    "sceneId": "sc_engine",
    "visibility": "searchable",
    "round": 1,
    "isKey": false,
    "pointsTo": [
      "c_sunmengzhen"
    ]
  },
  {
    "id": "cl_04",
    "title": "厨房中的简易床",
    "content": "铁鲸号厨房里有一张临时简易床，旁边有罐头和淡水——有人在航行期间一直藏身于此。床上有汗渍和泪痕。",
    "sceneId": "sc_kitchen",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "c_puchengshang"
    ]
  },
  {
    "id": "cl_05",
    "title": "仓库中的吊床",
    "content": "铁鲸号仓库里装有一张吊床，旁边有食物残渣和水壶——有人在航行期间一直藏身于此。",
    "sceneId": "sc_cargo",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "c_yanmuwan"
    ]
  },
  {
    "id": "cl_06",
    "title": "潜水过渡舱内的异常",
    "content": "潜水过渡舱充满海水，注水阀门被打开。一套潜水服立于水中，头盔连接着通往上方管道的长软管，一只手浮起，另一只手扣住阀门——海水因此不断灌入。不进入过渡舱就无法关闭阀门，但门被水压顶住无法打开。",
    "sceneId": "sc_diving_chamber",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "npc_zhangguren"
    ]
  },
  {
    "id": "cl_07",
    "title": "活章鱼",
    "content": "厨房中一个罐子里有一只不大的活章鱼——它不应该出现在潜艇中。章鱼被发现时触手不断翻动。",
    "sceneId": "sc_kitchen",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "c_yanmuwan",
      "c_sunmengzhen"
    ]
  },
  {
    "id": "cl_08",
    "title": "外国安眠药Schlaf",
    "content": "厨房中发现一种外国药，标签写着「Schlaf」——这是颜承古教授因失眠从青岛圣格林医院购买的安眠药。药瓶已被打开使用过。",
    "sceneId": "sc_kitchen",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "c_yanmuwan"
    ]
  },
  {
    "id": "cl_09",
    "title": "消防斧被移动的痕迹",
    "content": "潜水准备室的消防斧被从墙上取下过，斧柄上有摩擦痕迹——似乎曾被插入某处门把手中。",
    "sceneId": "sc_diving_prep",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "c_sunmengzhen"
    ]
  },
  {
    "id": "cl_10",
    "title": "船员舱通风口异常",
    "content": "船员舱上铺的通风口附近有布料纤维残留，通风管道内有被子的痕迹——有人曾用被子堵住通风口，连接着禁闭室的通风管道。",
    "sceneId": "sc_crew",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "c_sunmengzhen",
      "c_wangganhai"
    ]
  },
  {
    "id": "cl_11",
    "title": "注射器",
    "content": "在船长室右侧观景窗边发现一支空的注射器——船长死前曾举着它冲向众人。注射器中的液体已被注入某人体内。",
    "sceneId": "sc_bridge",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "c_yanmuwan",
      "npc_ouwen"
    ]
  },
  {
    "id": "cl_12",
    "title": "通风管道图纸",
    "content": "发电室中保存着铁鲸号的通风管道图纸：从储气舱运输空气，禁闭室→卫生间→船员舱是同一条通风管道。贵宾房和双人房共用另一条管道。",
    "sceneId": "sc_power",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "c_sunmengzhen"
    ]
  },
  {
    "id": "cl_13",
    "title": "小诺号残骸",
    "content": "从铁鲸号侧面探照灯可以看到远处海底有一堆被海底生物附着的东西——这就是沉没的小诺号残骸。潜艇被某种力量吸附在海底。",
    "sceneId": "sc_diving_chamber",
    "visibility": "searchable",
    "round": 1,
    "isKey": true,
    "pointsTo": [
      "npc_puchengxue",
      "npc_fanzongchu"
    ]
  },
  {
    "id": "cl_14",
    "title": "伊藤先生的字条",
    "content": "于跃洋随身携带一张字条：考察「铁鲸号」是否能用于未来的战争。这是伊藤先生交给他的秘密任务。",
    "sceneId": "sc_vip",
    "visibility": "searchable",
    "round": 1,
    "isKey": false,
    "pointsTo": [
      "c_yuyueyang"
    ]
  },
  {
    "id": "cl_15",
    "title": "樊宗楚的咖啡杯",
    "content": "仓库门外附近发现一个咖啡杯，杯中有水渍残留——这不是潜艇上常规使用的餐具。",
    "sceneId": "sc_cargo",
    "visibility": "searchable",
    "round": 1,
    "isKey": false,
    "pointsTo": [
      "c_yanmuwan"
    ]
  },
